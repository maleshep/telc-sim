# ─────────────────────────────────────────────────────────────────
# telc-a1-sim — Environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────

# ── Option A: Generic OpenAI-compatible endpoint (takes priority) ──
# Works with: OpenAI API, LM Studio, Ollama, Azure AI Foundry, Mistral, etc.
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_API_KEY=sk-...
VITE_OPENAI_MODEL=gpt-4o-mini          # LLM model for Schreiben/Sprechen scoring

# TTS (POST /audio/speech) — OpenAI TTS voices: alloy, echo, fable, onyx, nova, shimmer
VITE_OPENAI_TTS_MODEL=tts-1
VITE_OPENAI_TTS_VOICE=alloy

# STT (POST /audio/transcriptions) — Whisper
VITE_OPENAI_STT_MODEL=whisper-1

# ── Option B: Azure OpenAI / Merck NLP gateway ────────────────────
# Used when VITE_OPENAI_BASE_URL is not set.
VITE_AZURE_OPENAI_API_KEY=
VITE_AZURE_OPENAI_ENDPOINT=https://api.nlp.dev.uptimize.merckgroup.com
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-4o
VITE_AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Neural TTS (SSML, de-DE-KatjaNeural / de-DE-ConradNeural)
# Used when VITE_OPENAI_BASE_URL is not set for TTS.
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_ENDPOINT=https://api.nlp.dev.uptimize.merckgroup.com/azure_speech_services

# ─────────────────────────────────────────────────────────────────
# If neither option is configured, the app still works:
#   - LLM scoring → word-count heuristic (max 6/10 for Schreiben)
#   - TTS         → browser SpeechSynthesis (German voice, lower quality)
#   - STT         → browser SpeechRecognition (Chrome/Edge only)
# ─────────────────────────────────────────────────────────────────
